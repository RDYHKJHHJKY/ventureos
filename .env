# VentureOS Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://ventureos_user:password@localhost:5432/ventureos

# Node environment
NODE_ENV=development

# Server
PORT=5173
APP_URL=http://localhost:5173

# Session
SESSION_SECRET=your_session_secret_here

# CORS
CORS_ORIGIN=http://localhost:5173

# GitHub API
GITHUB_TOKEN=

# Snyk API
SNYK_TOKEN=

# SendGrid Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ventureos.com

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# Safety DB (for Python vulnerability checking)
SAFETY_DB_KEY=

# Logging
LOG_LEVEL=debug

# Azure (optional)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
